<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>gov.cms.bfd</groupId>
        <artifactId>bfd-server-parent</artifactId>
        <version>2.170.0-SNAPSHOT</version>
    </parent>

    <artifactId>bfd-server-image</artifactId>
    <packaging>jar</packaging>

    <description>
        Builds a BFD Server docker image using Jib plugin.
    </description>

    <properties>
        <!-- There is no java code to check. -->
        <checkstyle.skip>true</checkstyle.skip>
        <!-- There is no javadoc to generate. -->
        <maven.javadoc.skip>true</maven.javadoc.skip>
        <!-- Name of the image generated by jib plugin. -->
        <image-name>bfd-server</image-name>
    </properties>

    <dependencies>
        <dependency>
            <!-- BFD WAR file is required to build the image. -->
            <groupId>gov.cms.bfd</groupId>
            <artifactId>bfd-server-war</artifactId>
            <type>war</type>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <!-- BFD launcher zip file is required to build the image. -->
            <groupId>gov.cms.bfd</groupId>
            <artifactId>bfd-server-launcher</artifactId>
            <version>${project.version}</version>
        </dependency>
    </dependencies>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <!-- Configure the dependency plugin such that it can be used to grab
                        the dependency artifacts, for image creation. -->
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-dependency-plugin</artifactId>
                    <version>${maven.dependency.plugin.version}</version>
                    <configuration>
                        <overWriteReleases>false</overWriteReleases>
                        <overWriteSnapshots>true</overWriteSnapshots>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <!-- Copy the BFD war file into a directory for use in docker build. -->
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>${project.groupId}</groupId>
                                    <artifactId>bfd-server-war</artifactId>
                                    <version>${project.version}</version>
                                    <type>war</type>
                                    <outputDirectory>${project.build.directory}/war-file</outputDirectory>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                        <id>server-copy-war-for-docker</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                    </execution>
                    <execution>
                        <!-- Unpack the server launcher assembly for use in docker build. -->
                        <configuration>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>${project.groupId}</groupId>
                                    <artifactId>bfd-server-launcher</artifactId>
                                    <version>${project.version}</version>
                                    <type>zip</type>
                                    <outputDirectory>${project.build.directory}/server-launcher</outputDirectory>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                        <id>server-unpack-assembly</id>
                        <phase>package</phase>
                        <goals>
                            <goal>unpack</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <!-- Capture NR APM Java Agent for inclusion in deployment container -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.0.0</version>
                <executions>
                    <execution>
                        <?m2e execute onConfiguration,onIncremental?>
                        <id>download-nr</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>/usr/bin/curl</executable>
                            <arguments>
                                <argument>-o</argument>
                                <argument>${project.build.directory}/newrelic-java.zip</argument>
                                <argument>https://download.newrelic.com/newrelic/java-agent/newrelic-agent/current/newrelic-java.zip </argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>unzip-file</id>
                        <phase>package</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>unzip</executable>
                            <arguments>
                                <argument>${project.build.directory}/newrelic-java.zip</argument>
                                <argument>-d</argument>
                                <argument>${project.build.directory}/nr-java</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>template-server-script</id>
                        <phase>package</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>${project.build.directory}/../../bfd-server-launcher/src/main/assembly/bin/fill-template.sh</executable>
                            <arguments>
                                <argument>${project.build.directory}/../../bfd-server-launcher/src/main/assembly/bin/bfd-server.sh.tmpl</argument>
                                <argument>${project.build.directory}/../../bfd-server-launcher/src/main/assembly/bin/bfd-server.sh</argument>
                            </arguments>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <!-- Used to build docker image for the project. -->
                <groupId>com.google.cloud.tools</groupId>
                <artifactId>jib-maven-plugin</artifactId>
                <configuration>
                    <to>
                        <image>${jib.namespace}/bfd-server:${project.version}</image>
                        <tags>
                            <tag>${jib.tag}</tag>
                        </tags>
                    </to>
                    <from>
                        <image>${jib.from}</image>
                        <platforms>
                            <platform>
                                <architecture>amd64</architecture>
                                <os>linux</os>
                            </platform>
                        </platforms>
                    </from>
                    <container>
                        <!-- <mainClass>gov.cms.bfd.server.launcher.DataServerLauncherApp</mainClass> -->
                        <!--  <ports><port>6500</port></ports>  -->
                        <appRoot>/usr/local/bfd-server</appRoot>
                        <environment>
                            <BFD_VERSION>${project.version}</BFD_VERSION>
                        </environment>
                        <entrypoint>/usr/local/bfd-server/bin/bfd-server.sh</entrypoint>
                        <jvmFlags>-Dorg.jboss.logging.provider=slf4j</jvmFlags>
                        <ports>
                            <port>7443</port>
                        </ports>
                        <workingDirectory>/usr/local/${project.artifactId}</workingDirectory>
                    </container>
                    <extraDirectories>
                        <paths>
                            <!-- Copies war file into /app directory in container -->
                            <path>
                                <from>${project.build.directory}/war-file</from>
                                <!--  <into>/app</into>  -->
                                <into>/usr/local/bfd-server</into>
                            </path>
                            <!-- Copies Launcher artifacts into /app directory in container -->
                            <path>
                                <from>${project.build.directory}/server-launcher</from>
                                <!--  <into>/app</into>  -->
                                <into>/usr/local/bfd-server</into>
                            </path>
                            <path>
                                <from>${project.build.directory}/nr-java</from>
                                <into>/usr/local/bfd-server/newrelic</into>
                            </path>
                        </paths>
                        <permissions>
                            <permission>
                                <file>/usr/local/bfd-server/bin/*.sh</file>
                                <mode>755</mode>
                            </permission>
                        </permissions>
                    </extraDirectories>
                </configuration>
                <executions>
                    <execution>
                        <id>build-image</id>
                        <phase>package</phase>
                        <goals>
                            <goal>${jib.goal}</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
