#!/usr/bin/env groovy

properties([
        parameters([
                booleanParam(name: 'test_parameter', description: 'This is a test parameter'),
                string(name: 'test_param_string', description: 'Test parameter string type')
        ])
])

try {
    node {
        stage ("Example Call to build another Jenkins Job") {
            steps {
                build job: 'bfd-availability-checker-test',
                        parameters: [
                                [$class: 'StringParameterValue', name: 'ENVIRONMENT', value: "test"],
                                [$class: 'StringParameterValue', name: 'test_param_string', value: "wrapper passed in"]
                        ]
            }
        }
    }
} finally {

}