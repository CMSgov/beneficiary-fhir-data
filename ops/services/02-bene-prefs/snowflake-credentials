## Inject canonical SNOWFLAKE credential inot local environment by sourcing this file, i.e. `source snowflake-credentials`

BFD_ENV=prod
SSM_PATH_PREFIX="/bfd/${BFD_ENV}/idr-pipeline/sensitive"

SNOWFLAKE_ACCOUNT="$(aws ssm get-parameter --name "${SSM_PATH_PREFIX}/idr_account" --with-decryption --query "Parameter.Value" --output text --profile bfd-prod)"
export SNOWFLAKE_ACCOUNT

SNOWFLAKE_DATABASE="$(aws ssm get-parameter --name "${SSM_PATH_PREFIX}/idr_database" --with-decryption --query "Parameter.Value" --output text --profile bfd-prod)"
export SNOWFLAKE_DATABASE

SNOWFLAKE_PRIVATE_KEY_RAW="$(aws ssm get-parameter --name "${SSM_PATH_PREFIX}/idr_private_key" --with-decryption --query "Parameter.Value" --output text --profile bfd-prod)"
export SNOWFLAKE_PRIVATE_KEY_RAW

SNOWFLAKE_SCHEMA="$(aws ssm get-parameter --name "${SSM_PATH_PREFIX}/idr_schema" --with-decryption --query "Parameter.Value" --output text --profile bfd-prod)"
export SNOWFLAKE_SCHEMA

SNOWFLAKE_USER="$(aws ssm get-parameter --name "${SSM_PATH_PREFIX}/idr_username" --with-decryption --query "Parameter.Value" --output text --profile bfd-prod)"
export SNOWFLAKE_USER

SNOWFLAKE_WAREHOUSE="$(aws ssm get-parameter --name "${SSM_PATH_PREFIX}/idr_warehouse" --with-decryption --query "Parameter.Value" --output text --profile bfd-prod)"
export SNOWFLAKE_WAREHOUSE

