{# bcda.sql.j2 #}
with ordered_xref as (
    select
        bene_sk,
        bene_xref_sk,
        bene_hicn_num,
        src_rec_crte_ts,
        row_number() over (
            partition by bene_sk,
            bene_xref_sk
            order by
                src_rec_updt_ts desc
        ) as row_order
    from
        cms_vdm_view_mdcr_prd.v2_mdcr_bene_xref
),
current_xref as (
    select
        ox.bene_sk,
        ox.bene_xref_sk,
        bx.bene_kill_cred_cd,
        bx.src_rec_updt_ts,
        bx.idr_insrt_ts,
        bx.idr_updt_ts
    from
        ordered_xref ox
        join cms_vdm_view_mdcr_prd.v2_mdcr_bene_xref bx on bx.bene_sk = ox.bene_sk
        and bx.bene_xref_sk = ox.bene_xref_sk
        and bx.bene_hicn_num = ox.bene_hicn_num
        and bx.src_rec_crte_ts = ox.src_rec_crte_ts
    where
        ox.row_order = 1
),
beneficiaries_history as (
    select
        hstry.bene_mbi_id,
        hstry.bene_sk
    from
        cms_vdm_view_mdcr_prd.v2_mdcr_bene_hstry hstry
        left join current_xref xref on xref.bene_sk = hstry.bene_xref_sk
        and xref.bene_xref_sk = hstry.bene_sk
        and hstry.bene_mbi_id is not null
),
medprefs as (
select *
from
    idrc_prd.cms_vdm_view_mdcr_prd.v2_mdcr_bene_shrng_prefnc
where 
    bene_shrng_prefnc_type_cd = 'MED'                             {#- NOTE: only fetch 'MED' Coded preferences for BCDA #}
    and (idr_trans_obslt_ts = TO_DATE('9999-12-31', 'YYYY-MM-DD') {#- NOTE: only fetch the latest preference record #}
        and bene_shrng_prefnc_trmntn_dt > current_date())         {#- NOTE: only fetch preferences that haven't yet been terminated #}
),
saprefs as (                                                      {#- TODO: consider removing this CTE and subsequent join logic. Conditions for opt-in to SBABUSE sharing does not yet exist as of this writing, BFD does not support this. #}
select *
from idrc_prd.cms_vdm_view_mdcr_prd.v2_mdcr_bene_shrng_prefnc
where 
    bene_shrng_prefnc_type_cd = 'SBABUSE'                         {#- NOTE: only fetch 'SBABUSE' coded preferences for BCDA #}
    and (idr_trans_obslt_ts = TO_DATE('9999-12-31', 'YYYY-MM-DD') {#- NOTE: only fetch the latest preference record #}
        and bene_shrng_prefnc_trmntn_dt > current_date())         {#- NOTE: only fetch preferences that haven't yet been terminated #}
)
select distinct
    bh.bene_mbi_id as mbi,
    med.bene_sk as lkey,
    to_char(med.bene_shrng_prefnc_efctv_dt, 'YYYYMMDD') as effectivedt,
    med.bene_shrng_prefnc_sbmtr_type_cd as sourcecde,
    med.bene_shrng_prefnc_opt_in_sw as prefindtor,
    to_char(sa.bene_shrng_prefnc_efctv_dt, 'YYYYMMDD') as samhsaeffectivedt,
    sa.bene_shrng_prefnc_sbmtr_type_cd as samhsasourcecde,
    sa.bene_shrng_prefnc_opt_in_sw as samhsaprefindtor,
    scopedprefs.bene_shrng_scope_ent_id as acoid,
from medprefs med
full outer join saprefs sa on sa.bene_sk = med.bene_sk
join beneficiaries_history bh
    on bh.bene_sk = med.bene_sk
        and bh.bene_mbi_id is not null
left join idrc_prd.cms_vdm_view_mdcr_prd.v2_mdcr_bene_shrng_prefnc_scope scopedprefs
    on med.bene_sk = scopedprefs.BENE_SK
{% if query_since_timestamp != '' and query_until_timestamp != '' %}
where med.idr_insrt_ts BETWEEN to_timestamp('{{query_since_timestamp}}') AND to_timestamp('{{query_until_timestamp}}')
    OR sa.idr_insrt_ts BETWEEN to_timestamp('{{query_since_timestamp}}') AND to_timestamp('{{query_until_timestamp}}')
{% else %}
where to_date(med.idr_insrt_ts) = current_date()
    OR to_date(sa.idr_insrt_ts) = current_date()
{% endif %}
{# bcda.sql.j2 #}
