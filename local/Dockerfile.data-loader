FROM alpine:3.20

RUN apk add --no-cache postgresql16-client

WORKDIR /app

# Copy the sample RIF data
COPY apps/bfd-model/bfd-model-rif-samples/src/main/resources/rif-synthea /app/rif-data/

# Copy loader script
COPY local/load-data.sh /app/load-data.sh
RUN chmod +x /app/load-data.sh

ENTRYPOINT ["/app/load-data.sh"]
