FROM python:3.14-alpine

RUN apk add --no-cache postgresql16-client
RUN pip install --no-cache-dir psycopg2-binary

WORKDIR /app

# Copy the v3 IDR synthetic data
COPY apps/bfd-model-idr/synthetic-data /app/idr-data/

# Copy loader script
COPY local/load-data.py /app/load-data.py

ENTRYPOINT ["python", "/app/load-data.py"]
